- [ ] **Step 2: Create the TimelineDragState enum with documentation**

```swift
import Foundation

/// The current state of a drag operation on the timeline.
/// This state machine ensures drag operations follow a valid sequence and prevents invalid transitions.
enum TimelineDragState: Equatable {
    /// No drag in progress (initial and final state)
    case idle
    /// User pressed on clip, calculating initial position
    case dragStarted
    /// Clip is being dragged, snap calculations active
    case dragging
    /// Drag released, creating and executing operation
    case committing
    /// Drag cancelled (e.g., escape key), reverting position
    case cancelled

    /// Whether a drag operation is currently active
    var isDragging: Bool {
        switch self {
        case .dragStarted, .dragging, .committing:
            return true
        case .idle, .cancelled:
            return false
        }
    }

    /// Whether the state allows starting a new drag
    var canStartDrag: Bool {
        return self == .idle
    }

    /// Whether the state allows cancelling the current operation
    var canCancel: Bool {
        switch self {
        case .dragStarted, .dragging:
            return true
        case .idle, .committing, .cancelled:
            return false
        }
    }
}
```

- [ ] **Step 2: Write comprehensive tests for TimelineDragState**

```swift
import XCTest
@testable import OpenScreen

final class TimelineDragStateTests: XCTestCase {
    // MARK: - Equality Tests

    func testDragStateEquatable() {
        XCTAssertEqual(TimelineDragState.idle, .idle)
        XCTAssertEqual(TimelineDragState.dragStarted, .dragStarted)
        XCTAssertEqual(TimelineDragState.dragging, .dragging)
        XCTAssertEqual(TimelineDragState.committing, .committing)
        XCTAssertEqual(TimelineDragState.cancelled, .cancelled)

        XCTAssertNotEqual(TimelineDragState.idle, .dragging)
        XCTAssertNotEqual(TimelineDragState.dragStarted, .committing)
    }

    func testAllStatesAreDistinct() {
        let states: [TimelineDragState] = [.idle, .dragStarted, .dragging, .committing, .cancelled]

        // Verify all states are distinct
        for i in 0..<states.count {
            for j in (i+1)..<states.count {
                XCTAssertNotEqual(states[i], states[j], "States at index \(i) and \(j) should be different")
            }
        }
    }

    // MARK: - State Property Tests

    func testIsDraggingProperty() {
        XCTAssertTrue(TimelineDragState.dragStarted.isDragging)
        XCTAssertTrue(TimelineDragState.dragging.isDragging)
        XCTAssertTrue(TimelineDragState.committing.isDragging)

        XCTAssertFalse(TimelineDragState.idle.isDragging)
        XCTAssertFalse(TimelineDragState.cancelled.isDragging)
    }

    func testCanStartDragProperty() {
        XCTAssertTrue(TimelineDragState.idle.canStartDrag)

        XCTAssertFalse(TimelineDragState.dragStarted.canStartDrag)
        XCTAssertFalse(TimelineDragState.dragging.canStartDrag)
        XCTAssertFalse(TimelineDragState.committing.canStartDrag)
        XCTAssertFalse(TimelineDragState.cancelled.canStartDrag)
    }

    func testCanCancelProperty() {
        XCTAssertTrue(TimelineDragState.dragStarted.canCancel)
        XCTAssertTrue(TimelineDragState.dragging.canCancel)

        XCTAssertFalse(TimelineDragState.idle.canCancel)
        XCTAssertFalse(TimelineDragState.committing.canCancel)
        XCTAssertFalse(TimelineDragState.cancelled.canCancel)
    }

    // MARK: - State Transition Tests

    func testValidStateTransitions() {
        // Valid transition: idle → dragStarted
        var state = TimelineDragState.idle
        XCTAssertTrue(state.canStartDrag)
        state = .dragStarted

        // Valid transition: dragStarted → dragging
        state = .dragging
        XCTAssertTrue(state.isDragging)

        // Valid transition: dragging → committing
        state = .committing
        XCTAssertTrue(state.isDragging)

        // Valid transition: committing → idle (after operation completes)
        state = .idle
        XCTAssertTrue(state.canStartDrag)
    }

    func testCancellationTransition() {
        // Valid transition: dragStarted → cancelled
        var state = TimelineDragState.dragStarted
        XCTAssertTrue(state.canCancel)
        state = .cancelled
        XCTAssertFalse(state.isDragging)

        // Can start new drag after cancellation
        state = .idle
        XCTAssertTrue(state.canStartDrag)
    }

    func testCannotCancelFromIdle() {
        let state = TimelineDragState.idle
        XCTAssertFalse(state.canCancel)
    }

    func testCannotCancelFromCommitting() {
        let state = TimelineDragState.committing
        XCTAssertFalse(state.canCancel)
    }

    // MARK: - Switch Statement Tests

    func testDragStateCanBeUsedInSwitch() {
        let state: TimelineDragState = .dragging

        switch state {
        case .idle:
            XCTFail("Should be dragging")
        case .dragStarted, .dragging, .committing, .cancelled:
            // All valid states matched correctly
            break
        }
    }

    func testSwitchHandlesAllStates() {
        let allStates: [TimelineDragState] = [.idle, .dragStarted, .dragging, .committing, .cancelled]

        for state in allStates {
            switch state {
            case .idle, .dragStarted, .dragging, .committing, .cancelled:
                // All cases handled
                continue
            }
        }
    }
}
```

