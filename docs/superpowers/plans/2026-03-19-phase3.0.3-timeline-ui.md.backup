- [ ] **Step 3: Add test helpers for SnapPoint**

Append to TestDataFactory at end of file (after existing markers):

```swift
// MARK: - Timeline UI Models

extension TestDataFactory {
    /// Creates a test SnapPoint with default values
    static func makeSnapPoint(
        position: Double = 5.0,
        timescale: CMTimeScale = 600,
        type: SnapPointType = .clipEdge,
        source: String? = nil
    ) -> SnapPoint {
        let time = CMTime(seconds: position, preferredTimescale: timescale)
        return SnapPoint(position: time, type: type, source: source)
    }

    /// Creates a test SnapPoint at time zero
    static func makeSnapPointAtZero(type: SnapPointType = .trackBoundary) -> SnapPoint {
        return SnapPoint(position: .zero, type: type)
    }
```

- [ ] **Step 4: Add test helpers for SnapResult**

Add to TestDataFactory after SnapPoint helpers:

```swift
    /// Creates a test SnapResult with default values
    static func makeSnapResult(
        snapPosition: Double = 5.0,
        originalPosition: Double = 4.8,
        type: SnapPointType = .clipEdge,
        source: String? = nil
    ) -> SnapResult {
        let snapPoint = makeSnapPoint(position: snapPosition, type: type, source: source)
        let original = CMTime(seconds: originalPosition, preferredTimescale: 600)
        let snapped = CMTime(seconds: snapPosition, preferredTimescale: 600)
        return SnapResult(snapPoint: snapPoint, originalPosition: original, snappedPosition: snapped)
    }
```

- [ ] **Step 5: Add test helpers for ClipLayout**

Add to TestDataFactory after SnapResult helpers:

```swift
    /// Creates a test ClipLayout with default values
    static func makeClipLayout(
        clipID: UUID = UUID(),
        x: CGFloat = 100,
        y: CGFloat = 0,
        width: CGFloat = 200,
        height: CGFloat = 60,
        startTime: Double = 0,
        duration: Double = 5.0,
        isDirty: Bool = false
    ) -> ClipLayout {
        let frame = CGRect(x: x, y: y, width: width, height: height)
        let timeRange = CMTimeRange(
            start: CMTime(seconds: startTime, preferredTimescale: 600),
            duration: CMTime(seconds: duration, preferredTimescale: 600)
        )
        return ClipLayout(clipID: clipID, frame: frame, timeRange: timeRange, isDirty: isDirty)
    }

    /// Creates a zero ClipLayout (all zeros)
    static func makeZeroClipLayout(clipID: UUID = UUID()) -> ClipLayout {
        return ClipLayout(clipID: clipID, frame: .zero, timeRange: .zero, isDirty: false)
    }
}
```

- [ ] **Step 6: Write tests for helper methods**

Create test file to verify helpers work correctly:

```swift
import XCTest
import CoreGraphics
import CoreMedia
@testable import OpenScreen

final class TimelineModelHelpersTests: XCTestCase {
    // MARK: - SnapPoint Helper Tests

    func testMakeSnapPointCreatesValidSnapPoint() {
        let snapPoint = TestDataFactory.makeSnapPoint(
            position: 10.0,
            type: .playhead,
            source: "Test"
        )

        XCTAssertEqual(CMTimeGetSeconds(snapPoint.position), 10.0, accuracy: 0.01)
        XCTAssertEqual(snapPoint.type, .playhead)
        XCTAssertEqual(snapPoint.source, "Test")
    }

    func testMakeSnapPointAtZero() {
        let snapPoint = TestDataFactory.makeSnapPointAtZero(type: .trackBoundary)

        XCTAssertTrue(CMTimeGetSeconds(snapPoint.position) == 0)
        XCTAssertEqual(snapPoint.type, .trackBoundary)
    }

    // MARK: - SnapResult Helper Tests

    func testMakeSnapResultCreatesValidSnapResult() {
        let result = TestDataFactory.makeSnapResult(
            snapPosition: 5.0,
            originalPosition: 4.5,
            type: .clipEdge
        )

        XCTAssertEqual(CMTimeGetSeconds(result.snappedPosition), 5.0, accuracy: 0.01)
        XCTAssertEqual(CMTimeGetSeconds(result.originalPosition), 4.5, accuracy: 0.01)
        XCTAssertEqual(result.snapPoint.type, .clipEdge)
    }

    func testMakeSnapResultCalculatesOffset() {
        let result = TestDataFactory.makeSnapResult(
            snapPosition: 10.0,
            originalPosition: 9.0,
            type: .playhead
        )

        XCTAssertEqual(result.offsetSeconds, 1.0, accuracy: 0.01)
    }

    // MARK: - ClipLayout Helper Tests

    func testMakeClipLayoutCreatesValidLayout() {
        let clipID = UUID()
        let layout = TestDataFactory.makeClipLayout(
            clipID: clipID,
            x: 50,
            y: 60,
            width: 150,
            height: 40,
            startTime: 2.0,
            duration: 5.0
        )

        XCTAssertEqual(layout.clipID, clipID)
        XCTAssertEqual(layout.x, 50)
        XCTAssertEqual(layout.y, 60)
        XCTAssertEqual(layout.width, 150)
        XCTAssertEqual(layout.height, 40)
        XCTAssertEqual(CMTimeGetSeconds(layout.startTime), 2.0, accuracy: 0.01)
        XCTAssertEqual(CMTimeGetSeconds(layout.duration), 5.0, accuracy: 0.01)
    }

    func testMakeZeroClipLayout() {
        let layout = TestDataFactory.makeZeroClipLayout()

        XCTAssertEqual(layout.frame, .zero)
        XCTAssertEqual(layout.timeRange, .zero)
        XCTAssertFalse(layout.isDirty)
    }

    func testMakeClipLayoutWithDefaults() {
        let layout = TestDataFactory.makeClipLayout()

        XCTAssertEqual(layout.x, 100) // Default x
        XCTAssertEqual(layout.width, 200) // Default width
        XCTAssertEqual(layout.height, 60) // Default height
        XCTAssertTrue(CMTimeGetSeconds(layout.startTime) == 0) // Default start
        XCTAssertEqual(CMTimeGetSeconds(layout.duration), 5.0, accuracy: 0.01) // Default duration
    }
}
```

